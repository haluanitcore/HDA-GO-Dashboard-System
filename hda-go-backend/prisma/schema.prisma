generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ═══════════════════════════════════════════════════
// USER & AUTH
// ═══════════════════════════════════════════════════

model User {
  id            String          @id @default(uuid())
  name          String
  email         String          @unique
  password      String
  role          String          // CREATOR, CM, BRAND, ADMIN, EXECUTIVE
  created_at    DateTime        @default(now())
  
  // Settings & Profile
  avatar_url    String?
  bio           String?
  phone         String?
  cm_code       String?             // Kode unik CM (untuk matching sync Sheet)
  gdrive_url        String?         // Tautan Folder Google Drive (Khusus CM)
  gdrive_folder_id  String?         // Google Drive Folder ID (untuk API upload)
  
  creator       Creator?
  managed_creators Creator[] @relation("CreatorCM")
  notifications Notification[]
  preferences   UserPreferences?
  refreshTokens RefreshToken[]
}

model RefreshToken {
  id         String   @id @default(cuid())
  token_hash String   @unique
  user_id    String
  expires_at DateTime
  revoked    Boolean  @default(false)
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

// ═══════════════════════════════════════════════════
// CREATOR CORE
// ═══════════════════════════════════════════════════

model Creator {
  user_id           String             @id
  user              User               @relation(fields: [user_id], references: [id])
  creator_code      String?            @unique    // Creator ID dari Sheet (primary business key, e.g. TikTok user ID)
  creator_level     Int                @default(0)
  gmv_total         Float              @default(0)
  gmv_monthly       Float              @default(0)
  total_orders      Int                @default(0)
  total_campaigns   Int                @default(0)
  total_posts       Int                @default(0)
  streak_days       Int                @default(0)
  live_participation Int               @default(0)    // LIVE sessions joined
  posting_consistency Float            @default(0)    // % consistency score
  cm_id             String?
  cm_user           User?              @relation("CreatorCM", fields: [cm_id], references: [id])
  sheet_registered  Boolean            @default(false) // Apakah sudah terdaftar di Google Sheet

  progress          CreatorProgress?
  participants      CampaignParticipant[]
  submissions       Submission[]
  orders            CreatorOrder[]
  rewards           CreatorReward[]
  monthlyStats      CreatorMonthlyStats[]
  weeklyStats       CreatorWeeklyStats[]
  hotelVisits       HotelVisit[]

  // Biodata Section 1 - Identitas
  phone_number       String?
  gender             String?       // MALE, FEMALE
  birth_date         DateTime?
  domicile           String?

  // Biodata Section 2 - Konten
  tiktok_username    String?
  tiktok_url         String?
  tiktok_followers   Int?          @default(0)
  avg_views          Int?          @default(0)
  niche              String?       // JSON: '["FNB","FASHION"]'
  affiliate_exp      String?       // BARU, PERNAH, AKTIF

  // Biodata Section 3 - Kontrak
  sow_per_month      Int?          @default(0)
  gmv_target_monthly Float?        @default(0)
  start_date         DateTime?
  end_date           DateTime?     // Tanggal Akhir Kerja Sama / Masa Berakhir Kontrak
  cm_notes           String?

  // Status Onboarding
  onboarding_status  String        @default("PENDING") // PENDING, ACTIVE, INACTIVE
  onboarded_at       DateTime?
}

// ═══════════════════════════════════════════════════
// CREATOR LEVEL ENGINE
// ═══════════════════════════════════════════════════

model CreatorProgress {
  creator_id          String   @id
  creator             Creator  @relation(fields: [creator_id], references: [user_id])
  current_level       Int
  target_level        Int
  progress_percentage Float    @default(0)
  gmv_progress        Float    @default(0)
  campaign_progress   Int      @default(0)
  order_progress      Int      @default(0)
  updated_at          DateTime @updatedAt
}

// ═══════════════════════════════════════════════════
// CREATOR ASSIGNMENT LOG — Transfer audit trail
// ═══════════════════════════════════════════════════

model CreatorAssignmentLog {
  id             String   @id @default(uuid())
  creator_id     String
  from_cm_id     String?
  to_cm_id       String
  reason         String?
  transferred_by String
  transferred_at DateTime @default(now())
}

// ═══════════════════════════════════════════════════
// BD — BRAND-BD ASSIGNMENT
// Each BD user is assigned to specific brands
// ═══════════════════════════════════════════════════

model BrandBDAssignment {
  id                String     @id @default(uuid())
  bd_user_id        String                 // BD user assigned to this brand
  brand_user_id     String                 // Brand user
  assigned_at       DateTime   @default(now())
  is_active         Boolean    @default(true)

  @@unique([bd_user_id, brand_user_id])
}

// ═══════════════════════════════════════════════════
// CAMPAIGN SYSTEM
// Status Flow: PENDING_BD → BD_APPROVED / BD_REVISION → DRAFT → ACTIVE → COMPLETED / CANCELLED
// ═══════════════════════════════════════════════════

model Campaign {
  id                String                 @id @default(uuid())
  title             String
  category          String                 // HOTEL, FNB, TTD, LIVE, BEAUTY, TECH
  min_level         Int                    @default(0)
  brand_id          String
  sow_total         Int
  reward_type       String                 // FIXED, COMMISSION
  deadline          DateTime
  status            String                 // PENDING_BD, BD_APPROVED, BD_REVISION, DRAFT, ACTIVE, COMPLETED, CANCELLED
  budget            Float                  @default(0)
  brief_url         String?                // PDF brief attachment link
  bd_reviewer_id    String?                // BD user who reviewed
  bd_reviewed_at    DateTime?
  bd_notes          String?                // BD review notes / feedback
  bd_approved_at    DateTime?
  slot              Int                    @default(0)  // max participants
  created_at        DateTime               @default(now())
  qc_checklist      String?                // stringified JSON array of criteria

  // ── Phase 2: BD Hotel & FNB ──
  collaboration_type    String?            // VISIT_ONLY, BARTER_STAY, BARTER_DINING (Hotel only)
  target_creators_count Int                @default(0)  // Kuota jumlah kreator (all categories)
  start_date            DateTime?
  description           String?
  pic_contact           String?
  brief_text            String?
  
  participants      CampaignParticipant[]
  submissions       Submission[]
  orders            CreatorOrder[]
  rewards           CreatorReward[]
  analytics         CampaignAnalytics?
  editLogs          CampaignEditLog[]
  hotelVisits       HotelVisit[]
}

// ═══════════════════════════════════════════════════
// CAMPAIGN EDIT LOG — Audit Trail
// Tracks who edited what field on a campaign
// ═══════════════════════════════════════════════════

model CampaignEditLog {
  id                String     @id @default(uuid())
  campaign_id       String
  editor_id         String                 // User who made the edit
  editor_role       String                 // BRAND, BD, CM, ADMIN
  field_name        String                 // Which field was changed
  old_value         String?                // Previous value
  new_value         String?                // New value
  action            String                 // EDIT, APPROVE, REVISION, ASSIGN, CREATE
  notes             String?
  created_at        DateTime   @default(now())

  campaign          Campaign   @relation(fields: [campaign_id], references: [id])
}

model CampaignParticipant {
  campaign_id       String
  creator_id        String
  status            String                 // JOINED, APPROVED, REJECTED
  joined_at         DateTime               @default(now())

  campaign          Campaign               @relation(fields: [campaign_id], references: [id])
  creator           Creator                @relation(fields: [creator_id], references: [user_id])

  @@id([campaign_id, creator_id])
}

// ═══════════════════════════════════════════════════
// SUBMISSION & SOW TRACKING
// ═══════════════════════════════════════════════════

model Submission {
  id                String                 @id @default(uuid())
  campaign_id       String
  creator_id        String
  tiktok_url        String                 // Akan berisi GDrive link setelah upload selesai
  status            String                 // UPLOADING, QC_REVIEW, APPROVED, REVISION, POSTED, COMPLETED
  qc_notes          String?
  submitted_at      DateTime               @default(now())
  reviewed_at       DateTime?
  posted_at         DateTime?
  completed_at      DateTime?
  file_name         String?                // Nama file asli (e.g. "promo_v2.mp4")
  file_size         Int?                   // Ukuran file dalam bytes
  file_type         String?                // MIME type (video/mp4, image/jpeg)
  gdrive_file_id    String?                // Google Drive File ID
  quality_score     Int?                   // Rating 1-5
  checked_items     String?                // stringified JSON checklist state
  revision_count    Int                    @default(0) // count of soft-rejections
  revision_deadline DateTime?              // auto-calculated limit (2 days)
  schedule_posting  DateTime?              // custom publish timing
  qc_issues         String?                // stringified JSON of issue categories
  internal_tags     String?                // stringified JSON of admin tags (e.g. "Best Practice")
  reviewer_id       String?                // CM / Admin ID who processed the review

  // ── Phase 2: Link VT TikTok ──
  tiktok_vt_link    String?                // Link VT rill dari TikTok (https://www.tiktok.com/@user/video/123)

  campaign          Campaign               @relation(fields: [campaign_id], references: [id])
  creator           Creator                @relation(fields: [creator_id], references: [user_id])
  deliverable       SubmissionDeliverable?
}

model SubmissionDeliverable {
  submission_id     String     @id
  submission        Submission @relation(fields: [submission_id], references: [id])
  total_sow         Int
  completed_sow     Int        @default(0)
  remaining_sow     Int
}

// ═══════════════════════════════════════════════════
// GMV & ORDER TRACKING
// ═══════════════════════════════════════════════════

model CreatorOrder {
  id                String     @id @default(uuid())
  creator_id        String
  campaign_id       String
  order_count       Int        @default(0)
  gmv_amount        Float      @default(0)

  // ── NEW FIELDS ──
  source            String     @default("SELF_REPORT")
  status            String     @default("PENDING_VERIFICATION")
  proof_url         String?
  period_date       DateTime?
  notes             String?

  // Verifikasi
  verified_by       String?
  verified_at       DateTime?
  adjusted_amount   Float?
  reject_reason     String?

  // Override Admin
  override_by       String?
  override_reason   String?

  // Deadline verifikasi
  verification_deadline DateTime?

  recorded_at       DateTime   @default(now())

  creator           Creator    @relation(fields: [creator_id], references: [user_id])
  campaign          Campaign   @relation(fields: [campaign_id], references: [id])
}

model CreatorReward {
  id            String       @id @default(uuid())
  creator_id    String
  campaign_id   String
  reward_type   String       // FIXED | COMMISSION
  base_amount   Float        // Fee flat atau % GMV
  gmv_total     Float        // Total GMV yang jadi basis hitung
  reward_amount Float        // Angka final yang dibayarkan
  status        String       @default("PENDING") // PENDING, APPROVED, PAID, DISPUTED
  calculated_at DateTime     @default(now())
  paid_at       DateTime?

  creator       Creator      @relation(fields: [creator_id], references: [user_id])
  campaign      Campaign     @relation(fields: [campaign_id], references: [id])
}

// ═══════════════════════════════════════════════════
// NOTIFICATION SYSTEM
// ═══════════════════════════════════════════════════

model Notification {
  id                String     @id @default(uuid())
  user_id           String
  title             String
  message           String
  type              String     // SYSTEM, CAMPAIGN, REWARD, LEVEL_UP, QC, PUSH
  read_status       Boolean    @default(false)
  created_at        DateTime   @default(now())

  user              User       @relation(fields: [user_id], references: [id])
}

// ═══════════════════════════════════════════════════
// ANALYTICS AGGREGATION TABLES (Cron-populated)
// ═══════════════════════════════════════════════════

model CreatorMonthlyStats {
  id                String     @id @default(uuid())
  creator_id        String
  month             String     // Format: "2026-05"
  gmv               Float      @default(0)
  orders            Int        @default(0)
  campaigns_joined  Int        @default(0)
  campaigns_completed Int      @default(0)
  posts_count       Int        @default(0)
  completion_rate   Float      @default(0)   // % of SOW completed
  calculated_at     DateTime   @default(now())

  creator           Creator    @relation(fields: [creator_id], references: [user_id])

  @@unique([creator_id, month])
}

model CampaignAnalytics {
  id                String     @id @default(uuid())
  campaign_id       String     @unique
  total_participants Int       @default(0)
  total_submissions Int        @default(0)
  approved_submissions Int     @default(0)
  total_orders      Int        @default(0)
  total_gmv         Float      @default(0)
  completion_rate   Float      @default(0)
  calculated_at     DateTime   @default(now())

  campaign          Campaign   @relation(fields: [campaign_id], references: [id])
}

model PlatformMetrics {
  id                String     @id @default(uuid())
  date              String     @unique  // Format: "2026-05-08"
  total_creators    Int        @default(0)
  active_creators   Int        @default(0)
  total_campaigns   Int        @default(0)
  active_campaigns  Int        @default(0)
  total_gmv         Float      @default(0)
  total_orders      Int        @default(0)
  total_submissions Int        @default(0)
  calculated_at     DateTime   @default(now())
}

// ═══════════════════════════════════════════════════
// CREATOR WEEKLY STATS — Weekly GMV & Orders Tracking
// Updated via Google Sheet sync every week
// ═══════════════════════════════════════════════════

model CreatorWeeklyStats {
  id              String   @id @default(uuid())
  creator_id      String
  week_label      String   // Format: "2026-W24" (tahun-minggu ISO)
  week_start      DateTime // Senin awal minggu
  week_end        DateTime // Minggu akhir minggu
  gmv             Float    @default(0)
  orders          Int      @default(0)
  gmv_updated_at  DateTime? // Kapan data GMV terakhir diupdate
  source          String   @default("SHEET_SYNC") // SHEET_SYNC, MANUAL, SELF_REPORT
  notes           String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  creator         Creator  @relation(fields: [creator_id], references: [user_id])

  @@unique([creator_id, week_label])
}

// ═══════════════════════════════════════════════════
// USER PREFERENCES (Settings)
// ═══════════════════════════════════════════════════

model UserPreferences {
  id                   String   @id @default(uuid())
  user_id              String   @unique
  notif_submission     Boolean  @default(true)
  notif_campaign       Boolean  @default(true)
  notif_levelup        Boolean  @default(true)
  notif_recommendation Boolean  @default(true)
  default_sort         String? 
  show_inactive        Boolean  @default(true)
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt
  user                 User     @relation(fields: [user_id], references: [id])
}

// ═══════════════════════════════════════════════════
// PHASE 2: HOTEL PARTNER — Mitra Hotel Database
// Populated via Excel upload by BD
// ═══════════════════════════════════════════════════

model HotelPartner {
  id          String       @id @default(uuid())
  name        String
  location    String
  city        String?
  category    String?      // HOTEL, RESORT, VILLA, RESTAURANT
  facilities  String?      // JSON stringified
  contact     String?
  province    String?
  quota       Int          @default(1)
  pic_name    String?
  pic_phone   String?
  is_active   Boolean      @default(true)
  created_at  DateTime     @default(now())

  hotelVisits HotelVisit[]
}

// ═══════════════════════════════════════════════════
// PHASE 2: HOTEL VISIT — Kunjungan Kreator ke Hotel
// Links Creator ↔ Campaign ↔ HotelPartner
// ═══════════════════════════════════════════════════

model HotelVisit {
  id              String       @id @default(uuid())
  campaign_id     String
  creator_id      String
  hotel_id        String

  visit_type      String       // VISIT_ONLY, BARTER_STAY, BARTER_DINING
  visit_date      DateTime     // Tanggal kunjungan rencana
  visit_time      String       // Jam kunjungan rencana (e.g. "11:00")
  visit_location  String?      // Lokasi spesifik dalam hotel
  status          String       @default("PENDING") // PENDING, APPROVED, COMPLETED, CANCELLED
  notes           String?

  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt

  campaign        Campaign     @relation(fields: [campaign_id], references: [id])
  creator         Creator      @relation(fields: [creator_id], references: [user_id])
  hotel           HotelPartner @relation(fields: [hotel_id], references: [id])
}

model SystemSetting {
  key        String   @id
  value      String
  updated_at DateTime @updatedAt
}

